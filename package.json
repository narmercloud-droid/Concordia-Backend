{
  "name": "concordia-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "render-build": "npm run build",
    "start": "node dist/index.js",
    "start:cluster": "node dist/cluster.js",
    "start:pm2": "pm2 start ecosystem.config.js --no-daemon",
    "start:pm2:prod": "pm2 start ecosystem.config.js --env production --no-daemon",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:ui": "playwright test",
    "test:all": "npm run test && npm run test:ui",
    "lint": "tsc --noEmit",
    "load:orders": "k6 run load-tests/orders.js",
    "load:sockets": "k6 run load-tests/sockets.js",
    "load:ai": "k6 run load-tests/ai-endpoints.js",
    "load:admin": "k6 run load-tests/admin-dashboard.js",
    "load:all": "npm run load:orders && npm run load:sockets && npm run load:ai && npm run load:admin"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.55.2",
    "@sentry/profiling-node": "^8.55.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.19.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.9.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "morgan": "^1.10.1",
    "pg": "^8.11.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react-leaflet": "^5.0.0",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.40",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "pm2": "^5.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
