{
  "name": "concordia-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node-esm src/index.ts",
    "prebuild": "npx prisma generate",
    "build": "tsc",
    "postinstall": "prisma generate",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:push": "npx prisma db push",
    "render-build": "npm run build",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "start:dev": "nest start --watch",
    "seed": "ts-node-esm prisma/seed.ts",
    "seed:branches": "node prisma/seed_branches.mjs",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "lifecycle:test": "node scripts/lifecycle_tests/run_lifecycle_tests.mjs",
    "test:ui": "playwright test",
    "test:all": "npm run test && npm run test:ui"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.45.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bonjour": "^3.5.1",
    "buffer-crc32": "^1.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.22.2",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.9.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "morgan": "^1.10.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "prom-client": "^14.0.0",
    "qrcode": "^1.5.4",
    "react-leaflet": "^5.0.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
