{
  "name": "concordia-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node-esm src/index.ts",
    "prebuild": "npx prisma generate",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/copy-build-assets.mjs",
    "postinstall": "prisma generate",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:push": "npx prisma db push",
    "render-build": "npx prisma migrate deploy && npm run build",
    "start": "node --enable-source-maps dist/index.js",
    "start:worker": "node dist/worker.js",
    "start:dev": "nest start --watch",
    "seed": "ts-node-esm prisma/seed.ts",
    "seed:concordia": "node scripts/seed-concordia.mjs",
    "sync:kempen-menu": "node scripts/sync-kempen-menu.mjs",
    "setup:kempen-categories": "node scripts/setup-kempen-categories.mjs",
    "apply:kempen-menu-layout": "node scripts/apply-kempen-menu-layout.mjs",
    "apply:kempen-pizza-extras": "node scripts/apply-kempen-pizza-extras.mjs",
    "apply:kempen-calzones": "node scripts/apply-kempen-calzones.mjs",
    "apply:kempen-pizzabroetchen-extras": "node scripts/apply-kempen-pizzabroetchen-extras.mjs",
    "apply:kempen-schnitzel-options": "node scripts/apply-kempen-schnitzel-options.mjs",
    "apply:kempen-burger-extras": "node scripts/apply-kempen-burger-extras.mjs",
    "apply:kempen-all-extras": "npm run apply:kempen-pizza-extras && npm run apply:kempen-calzones && npm run apply:kempen-pizzabroetchen-extras && npm run apply:kempen-schnitzel-options && npm run apply:kempen-burger-extras",
    "sync:straelen-menu": "node scripts/sync-straelen-menu.mjs",
    "setup:straelen": "node scripts/setup-straelen-branch.mjs",
    "import:straelen-menu": "node scripts/import-straelen-menu.mjs",
    "activate:straelen": "node scripts/activate-straelen-branch.mjs",
    "seed:admins": "node scripts/seed-admins.mjs",
    "seed:promo": "node scripts/seed-promo-codes.mjs",
    "import:kempen-menu": "node scripts/parse-kempen-menu.mjs",
    "extract:lieferando": "node scripts/extract-lieferando-complete.mjs",
    "delete:test-branch": "node scripts/delete-test-branch.mjs",
    "menu:export": "node scripts/export-menu-catalog.mjs",
    "menu:locales": "node scripts/generate-menu-locales.mjs",
    "sync:google-reviews": "node scripts/sync-google-reviews.mjs",
    "extract:google-maps-reviews": "node scripts/extract-google-maps-reviews.mjs",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "lifecycle:test": "node scripts/lifecycle_tests/run_lifecycle_tests.mjs",
    "test:ui": "playwright test",
    "test:all": "npm run test && npm run test:ui",
    "validate": "prisma validate",
    "env-check": "node scripts/validateEnv.js",
    "profile": "node scripts/profile.js",
    "pm2": "pm2 start ecosystem.config.js",
    "smoke": "node scripts/smoke-test.js",
    "sdk:manifest": "node sdk-tests/generate-manifest.cjs",
    "sdk:test": "node sdk-tests/run-tests.cjs"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.45.0",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bonjour": "^3.5.1",
    "buffer-crc32": "^1.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.22.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.9.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^8.6.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "prom-client": "^14.0.0",
    "qrcode": "^1.5.4",
    "react-leaflet": "^5.0.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.2.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "xss-clean": "^0.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@nestjs/cli": "^11.0.21",
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^5.8.4",
    "@types/qrcode": "^1.5.6",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "ajv": "^8.12.0",
    "eslint": "^8.57.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.4.2",
    "js-yaml": "^4.1.0",
    "node-fetch": "^2.6.7",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
