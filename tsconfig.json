{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": false,

    "types": ["node"],

    "rootDir": "./src",
    "outDir": "./dist",

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false
  },

  "include": [
    "src/index.ts",
    "src/routes/**/*",
    "src/controllers/**/*",
    "src/middleware/**/*",
    "src/utils/**/*",
    "src/services/push.service.ts",
    "src/services/sms.service.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/services/experimental",
    "src/services/ai",
    "src/services/forecasting*",
    "src/services/dynamicPricing*",
    "src/services/ltvChurn*",
    "src/services/behaviorPrediction*",
    "src/services/knowledgeGraph*",
    "src/services/menuOptimization*",
    "src/services/staffingPrep*",
    "src/services/optimizationLoop*",
    "src/services/orchestration*"
  ]
}
