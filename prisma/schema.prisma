generator client {
  provider = "prisma-client-js"
}

model KitchenDisplay {
  id        String   @id @default(uuid())
  name      String
  apiKey    String   @unique
  branchId  String
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
}

// PHASE 1 — CREATE ANALYTICS DATA MODELS
model CustomerAnalytics {
  id              String   @id @default(uuid())
  customerId      String   @unique
  totalOrders     Int      @default(0)
  totalSpend      Float    @default(0)
  avgOrderValue   Float    @default(0)
  lastOrderDate   DateTime?
  churnRiskScore  Float    @default(0)
  lifetimeValueScore Float @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  
  @@index([customerId])
}

model MenuItemAnalytics {
  id             String   @id @default(uuid())
  itemId         String   @unique
  totalOrders    Int      @default(0)
  totalRevenue   Float    @default(0)
  popularityScore Float   @default(0)
  lastOrderedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  item MenuItem @relation(fields: [itemId], references: [id])
  
  @@index([itemId])
}

model CourierPerformance {
  id               String   @id @default(uuid())
  courierId        String   @unique
  totalDeliveries  Int      @default(0)
  avgDeliveryTime  Float    @default(0)
  onTimeRate       Float    @default(0)
  ratingScore      Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  courier Courier @relation(fields: [courierId], references: [id])
  
  @@index([courierId])
}

model BranchDemand {
  id              String   @id @default(uuid())
  branchId        String
  date            DateTime
  hour            Int
  orderCount      Int      @default(0)
  predictedDemand Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
  
  @@index([branchId, date, hour])
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id         String  @id @default(uuid())
  branchId   String
  customerId String?
  isGuest    Boolean @default(false)

  paymentMethod String // "cash" | "online"
  paymentStatus String @default("pending") // pending, paid, failed

  paymentIntentId String?
  paypalOrderId   String?
  paypalCaptureId String?

  status String @default("pending") // pending, accepted, preparing, ready_for_pickup, picked_up, delivered, cancelled

  scheduledFor          DateTime?
  courierToken          String?
  courierTokenExpiresAt DateTime?
  courierStatus         String? // accepted, picked_up, delivered

  tracking_token String?
  terminal_id    String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch             Branch               @relation(fields: [branchId], references: [id])
  customer           Customer?            @relation(fields: [customerId], references: [id])
  OrderTrackingEvent OrderTrackingEvent[]
  Review             Review?
  RiskScore          RiskScore?
  OrderRiskEvent     OrderRiskEvent[]

  @@index([branchId, createdAt])
  @@index([customerId, createdAt])
  @@index([branchId, status])
  @@index([status, createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  itemId    String
  variantId String
  addOnIds  String[] @default([])
  quantity  Int      @default(1)
  notes     String?

  price Float

  order      Order       @relation(fields: [orderId], references: [id])
  item       MenuItem   @relation(fields: [itemId], references: [id])
  ItemRating ItemRating?

  @@index([orderId])
  @@index([itemId])
}

model Branch {
  id      String  @id @default(uuid())
  name    String
  address String?
  phone   String?
  lat     Float?
  lng     Float?
  cuisine String?
  active  Boolean @default(true)

  orders         Order[]
  deliveryZone   DeliveryZone?
  BranchSchedule BranchSchedule[]
  Review         Review[]
  terminals      Terminal[]
  kitchenDisplays KitchenDisplay[]
  couriers       Courier[]
  branchDemand   BranchDemand[]
}

model Terminal {
  id               String   @id @default(uuid())
  name             String
  activation_token String   @unique
  branchId         String
  isOnline         Boolean  @default(false)
  lastSeen         DateTime?
  createdAt        DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
}

model Customer {
  id    String  @id @default(uuid())
  name  String
  email String  @unique
  phone String?

  orders                 Order[]
  notificationPreference NotificationPreference?
  loyaltyPoints          LoyaltyPoints?
  referral               Referral?
  favorites              Favorite[]
  addresses              Address[]
  Review                 Review[]
  customerAnalytics      CustomerAnalytics?
}

model Courier {
  id      String  @id @default(uuid())
  name    String
  email   String  @unique
  phone   String
  vehicle String?
  active  Boolean @default(true)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  locations CourierLocation[]
  courierPerformance CourierPerformance?

  @@index([branchId])
  @@index([active])
}

model Admin {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     String // "admin" | "manager"
  branchId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationPreference {
  id         String  @id @default(uuid())
  customerId String  @unique
  allowPush  Boolean @default(true)
  allowSMS   Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id])
}

model LoyaltyPoints {
  id         String @id @default(uuid())
  customerId String @unique
  points     Int    @default(0)

  customer Customer @relation(fields: [customerId], references: [id])
}

model Reward {
  id          String  @id @default(uuid())
  title       String
  description String?
  costPoints  Int
  discount    Float? // percentage discount (0.1 = 10%)
  amountOff   Float? // fixed discount
  freeItemId  String? // optional free item reward

  createdAt DateTime @default(now())
}

model PromoCode {
  id        String    @id @default(uuid())
  code      String    @unique
  discount  Float? // percentage
  amountOff Float? // fixed amount
  expiresAt DateTime?
  maxUses   Int?
  usedCount Int       @default(0)

  createdAt DateTime @default(now())
}

model Referral {
  id            String @id @default(uuid())
  customerId    String @unique
  code          String @unique
  referredCount Int    @default(0)

  customer Customer @relation(fields: [customerId], references: [id])
}

model MenuItem {
  id                String   @id @default(uuid())
  name              String
  description       String?
  price             Float
  tags              String[] @default([])
  stock             Int?     @default(999999)
  lowStockThreshold Int?     @default(5)
  autoDisable       Boolean  @default(true)

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  favorites    Favorite[]
  PriceHistory PriceHistory[]
  orderItems  OrderItem[]
  relations   Relation[]
  cartItems   CartItem[]
  menuItemAnalytics MenuItemAnalytics?
}

model Favorite {
  id         String   @id @default(uuid())
  customerId String
  itemId     String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  item     MenuItem @relation(fields: [itemId], references: [id])

  @@unique([customerId, itemId])
}

model Address {
  id           String  @id @default(uuid())
  customerId   String
  label        String
  street       String
  city         String
  postalCode   String
  lat          Float?
  lng          Float?
  instructions String?
  isDefault    Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

model DeliveryZone {
  id                    String @id @default(uuid())
  branchId              String @unique
  maxDistanceKm         Float
  baseFee               Float
  perKmFee              Float
  freeDeliveryThreshold Float?
  minimumOrderAmount    Float?

  branch Branch @relation(fields: [branchId], references: [id])
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  position    Int     @default(0)
  items       MenuItem[]
}

model Deal {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
  visible     Boolean @default(true)
}

model Extra {
  id          String  @id @default(uuid())
  name        String
  price       Float
  visible     Boolean @default(true)
}

model Topping {
  id          String  @id @default(uuid())
  name        String
  price       Float
  visible     Boolean @default(true)
}

model Variant {
  id          String  @id @default(uuid())
  name        String
  price       Float
  visible     Boolean @default(true)
}

model Relation {
  id          String  @id @default(uuid())
  itemId      String
  variantId   String?
  toppingId   String?
  extraId     String?
  item        MenuItem @relation(fields: [itemId], references: [id])
}

model Cart {
  id         String     @id @default(uuid())
  customerId String?
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  itemId    String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id])
  item      MenuItem @relation(fields: [itemId], references: [id])

  @@index([cartId])
  @@index([itemId])
}

model SearchLog {
  id        String   @id @default(uuid())
  query     String
  createdAt DateTime @default(now())
}

model BranchSchedule {
  id        String @id @default(uuid())
  branchId  String
  day       Int // 0 = Monday, 6 = Sunday
  openTime  String
  closeTime String

  branch Branch @relation(fields: [branchId], references: [id])
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   // "owner" | "superadmin"
  refreshToken String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CourierLocation {
  id        String   @id @default(uuid())
  courierId String   @unique
  lat       Float
  lng       Float
  speed     Float?
  heading   Float?
  updatedAt DateTime @updatedAt

  courier Courier @relation(fields: [courierId], references: [id])
}

model OrderTrackingEvent {
  id        String   @id @default(uuid())
  orderId   String
  status    String // accepted, preparing, picked_up, en_route, delivered
  timestamp DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([timestamp])
}

model Review {
  id         String   @id @default(uuid())
  orderId    String   @unique
  customerId String
  branchId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order    Order    @relation(fields: [orderId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@index([customerId])
  @@index([branchId, createdAt])
  @@index([createdAt])
}

model ItemRating {
  id          String @id @default(uuid())
  orderItemId String @unique
  rating      Int

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
}

model RiskScore {
  id        String   @id @default(uuid())
  orderId   String   @unique
  score     Int
  level     String // low, medium, high, extreme
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model FraudFlag {
  id         String   @id @default(uuid())
  customerId String?
  orderId    String?
  reason     String
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([orderId])
  @@index([createdAt])
}

model OrderRiskEvent {
  id        String   @id @default(uuid())
  orderId   String
  event     String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

model PriceHistory {
  id        String   @id @default(uuid())
  itemId    String
  oldPrice  Float
  newPrice  Float
  reason    String
  createdAt DateTime @default(now())

  item MenuItem @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@index([createdAt])
}

model DynamicPriceRule {
  id         String   @id @default(uuid())
  branchId   String
  itemId     String?
  ruleType   String // demand, inventory, time, surge, discount
  multiplier Float?
  amount     Float?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([branchId])
  @@index([active, createdAt])
}

model InsightLog {
  id          String   @id @default(uuid())
  branchId    String
  type        String // pattern, anomaly, correlation
  description String
  confidence  Float
  impact      String // low, medium, high
  createdAt   DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([type])
}

model DecisionLog {
  id          String   @id @default(uuid())
  branchId    String
  actionType  String // pricing, marketing, inventory, staffing, retention, fraud
  description String
  confidence  Float
  impact      String // low, medium, high
  autoApplied Boolean
  createdAt   DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([actionType])
}

model AutomationSettings {
  id        String  @id @default(uuid())
  branchId  String  @unique
  pricing   Boolean @default(false)
  marketing Boolean @default(false)
  inventory Boolean @default(false)
  staffing  Boolean @default(false)
  retention Boolean @default(false)
  fraud     Boolean @default(false)
}

model AnalyticsQueryLog {
  id        String   @id @default(uuid())
  branchId  String
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model OptimizationLog {
  id        String   @id @default(uuid())
  branchId  String
  module    String // pricing, forecasting, churn, behavior, staffing, inventory
  parameter String
  oldValue  Float?
  newValue  Float?
  reason    String
  createdAt DateTime @default(now())
}

model OptimizationParameters {
  id                 String @id @default(uuid())
  branchId           String @unique
  pricingMultiplier  Float  @default(1.0)
  forecastWeight     Float  @default(1.0)
  churnThreshold     Float  @default(0.5)
  behaviorConfidence Float  @default(0.7)
  staffingRatio      Float  @default(3.0)
  inventoryThreshold Float  @default(2.0)
}

model OrchestrationLog {
  id        String   @id @default(uuid())
  branchId  String
  cycleType String // scheduled, event-triggered, manual
  summary   String
  createdAt DateTime @default(now())
}

model MemoryRecord {
  id        String   @id @default(uuid())
  branchId  String
  module    String // forecasting, pricing, churn, behavior, staffing, insights, decisions
  key       String
  value     Json
  createdAt DateTime @default(now())
}

model TrendRecord {
  id        String   @id @default(uuid())
  branchId  String
  category  String // demand, pricing, churn, behavior, inventory
  summary   String
  createdAt DateTime @default(now())
}

model IntelligenceReport {
  id        String   @id @default(uuid())
  branchId  String
  summary   String
  details   Json
  createdAt DateTime @default(now())
}

model DashboardViewLog {
  id        String   @id @default(uuid())
  branchId  String
  section   String
  createdAt DateTime @default(now())
}

model ConversationLog {
  id        String   @id @default(uuid())
  branchId  String
  message   String
  response  String
  createdAt DateTime @default(now())
}
