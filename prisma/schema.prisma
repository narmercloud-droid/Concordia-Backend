generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id                    String               @id @default(uuid())
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  branchId              String
  courierStatus         String?
  courierToken          String?
  courierTokenExpiresAt DateTime?
  customerId            String?
  isGuest               Boolean              @default(false)
  paymentIntentId       String?
  paymentMethod         String?
  paymentStatus         String               @default("pending")
  paypalCaptureId       String?
  paypalOrderId         String?
  scheduledFor          DateTime?
  status                String               @default("pending")
  courierId             String?
  externalAmount        Decimal?             @default(0.00)
  paidAt                DateTime?
  terminal_id           String?
  tracking_token        String?              @unique
  transactionId         String?
  walletUsed            Decimal?             @default(0.00)
  kitchenStatus         String               @default("pending")
  kitchenUpdatedAt      DateTime?
  driverSessionId       String?
  customerEmail         String?
  customerPhone         String?
  customerName          String?
  deliveryAddress       String?
  fulfillmentType       String?              @default("delivery")
  postalCode            String?
  notes                 String?
  orderTotal            Float?
  deliveryFee           Float?               @default(0)
  deliveryLat           Float?
  deliveryLng           Float?
  driverAcceptedAt      DateTime?
  pushToken             String?
  confirmedAt           DateTime?
  deliveredAt           DateTime?
  pickedUpAt            DateTime?
  preparingAt           DateTime?
  readyAt               DateTime?
  discount              Float                @default(0)
  promoCodeId           String?
  giftCardId            String?
  giftCardAmount        Float?
  freeDrinkChoice       String?
  marketingEmail        Boolean              @default(false)
  marketingSMS          Boolean              @default(false)
  marketingWhatsApp     Boolean              @default(false)
  marketingConsentAt    DateTime?
  estimatedDriverTime   Int?
  estimatedPrepTime     Int?
  estimatedTotalTime    Int?
  etaDeliveredAt        DateTime?
  etaReadyAt            DateTime?
  assignedAt            DateTime?
  assignmentScore       Float?
  autoAssigned          Boolean              @default(false)
  cartItems             CartItem[]
  courierLocations      CourierLocation[]    @relation("OrderCourierLocations")
  driverRatings         DriverRating[]
  branch                Branch               @relation(fields: [branchId], references: [id])
  Courier               Courier?             @relation(fields: [courierId], references: [id])
  customer              Customer?            @relation(fields: [customerId], references: [id])
  orderIssues           OrderIssue[]
  items                 OrderItem[]
  orderRiskEvents       OrderRiskEvent[]     @relation("OrderOrderRiskEvents")
  trackingEvents        OrderTrackingEvent[] @relation("OrderTrackingEvents")
  review                Review?              @relation("OrderReview")
  riskScore             RiskScore?           @relation("OrderRiskScore")
  terminalEvents        TerminalEvent[]      @relation("OrderTerminalEvents")
}

model OrderItem {
  id         String             @id @default(uuid())
  quantity   Int                @default(1)
  addOnIds   String[]           @default([])
  notes      String?
  orderId    String
  price      Float
  variantId  String
  itemId     Int
  ItemRating ItemRating?
  item       MenuItem           @relation(fields: [itemId], references: [id])
  order      Order              @relation(fields: [orderId], references: [id])
  extras     OrderItemExtra[]
  variants   OrderItemVariant[]
}

model OrderItemVariant {
  id          String    @id @default(uuid())
  orderItemId String
  name        String
  price       Decimal   @db.Decimal(10, 2)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
}

model OrderItemExtra {
  id          String    @id @default(uuid())
  orderItemId String
  name        String
  price       Decimal   @db.Decimal(10, 2)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
}

model Branch {
  id                       String                   @id @default(uuid())
  name                     String
  createdAt                DateTime                 @default(now())
  printerType              String
  printerUrl               String?
  avgPrepTimeBaseline      Int                      @default(15)
  currentLoadLevel         Int                      @default(0)
  ActivationCode           ActivationCode[]
  BranchCategory           BranchCategory[]
  BranchConfig             BranchConfig?
  branchHours              BranchHours[]
  branchItemAvailabilities BranchItemAvailability[]
  branchItemPricings       BranchItemPricing[]
  BranchMenuItem           BranchMenuItem[]
  BranchExtraPreset        BranchExtraPreset[]
  BranchSchedule           BranchSchedule[]
  BranchTerminal           BranchTerminal[]
  couriers                 Courier[]
  deliveryZone             DeliveryZone?
  Device                   Device[]
  Driver                   Driver[]
  kitchenDisplays          KitchenDisplay[]
  Manager                  Manager[]
  orders                   Order[]
  Review                   Review[]
  terminals                Terminal[]
  paymentSettings          BranchPaymentSettings?
}

model BranchPaymentSettings {
  branchId               String   @id
  stripeAccountId        String?
  stripeChargesEnabled   Boolean  @default(false)
  stripeDetailsSubmitted Boolean  @default(false)
  stripePayoutsEnabled   Boolean  @default(false)
  cardEnabled            Boolean  @default(true)
  applePayEnabled        Boolean  @default(true)
  googlePayEnabled       Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  branch                 Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String         @id @default(uuid())
  email     String         @unique
  password  String
  createdAt DateTime       @default(now())
  name      String
  role      String         @default("admin")
  branchId  String?
  sessions  AdminSession[]
}

model ManagerPermissionPolicy {
  id          String   @id @default("default")
  permissions Json
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model Manager {
  id        String           @id @default(uuid())
  email     String           @unique
  password  String
  branchId  String
  createdAt DateTime         @default(now())
  branch    Branch           @relation(fields: [branchId], references: [id])
  sessions  ManagerSession[]
}

model Terminal {
  id               String    @id @default(uuid())
  name             String
  activation_token String    @unique
  branchId         String
  isOnline         Boolean   @default(false)
  lastSeen         DateTime?
  createdAt        DateTime  @default(now())
  branch           Branch    @relation(fields: [branchId], references: [id])
}

model Customer {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String                  @unique
  passwordHash           String?
  phone                  String?
  loginToken             String?                 @db.VarChar(255)
  loginTokenExpires      DateTime?
  loyaltyPoints          Int                     @default(0)
  marketingConsent       Boolean                 @default(false)
  marketingConsentAt     DateTime?
  marketingEmail         Boolean                 @default(false)
  marketingSMS           Boolean                 @default(false)
  marketingWhatsApp      Boolean                 @default(false)
  phoneNumber            String?                 @db.VarChar(255)
  lifetimePoints         Int                     @default(0)
  loyaltyTier            String                  @default("bronze")
  addresses              Address[]
  CustomerSession        CustomerSession[]
  favorites              Favorite[]
  loyaltyPointsRecord    LoyaltyPoints?
  notificationPreference NotificationPreference?
  orders                 Order[]
  orderIssues            OrderIssue[]
  referral               Referral?
  Review                 Review[]
  userRewards            UserReward[]
}

model Courier {
  id        String            @id @default(uuid())
  name      String
  email     String            @unique
  phone     String
  vehicle   String?
  active    Boolean           @default(true)
  branchId  String
  branch    Branch            @relation(fields: [branchId], references: [id])
  locations CourierLocation[]
  Order     Order[]
}

model Driver {
  id              String         @id @default(uuid())
  name            String
  email           String?        @unique
  phone           String?
  branchId        String
  isAvailable     Boolean        @default(true)
  currentOrderId  String?
  earnings        Float          @default(0)
  password        String?
  avgDeliveryTime Int?
  cancelledOrders Int            @default(0)
  completedOrders Int            @default(0)
  onTimeRate      Float          @default(1.0)
  ratingAverage   Float          @default(5.0)
  ratingCount     Int            @default(0)
  branch          Branch         @relation(fields: [branchId], references: [id])
  driverRatings   DriverRating[]
}

model BranchSettings {
  id           Int      @id @default(autoincrement())
  branchId     String   @unique
  printingMode String   @default("direct")
  autoPrint    Boolean  @default(true)
  printCopies  Int      @default(1)
  routingMode  String   @default("kitchen")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LoyaltySettings {
  id                 String   @id @default(uuid())
  pointsPerCurrency  Float    @default(1)
  silverThreshold    Int      @default(1000)
  goldThreshold      Int      @default(2500)
  platinumThreshold  Int      @default(5000)
  allowPromoStacking Boolean  @default(true)
  pointsExpireMonths Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Reward {
  id          String       @id @default(uuid())
  name        String
  description String?
  costPoints  Int
  isActive    Boolean      @default(true)
  userRewards UserReward[]
}

model UserReward {
  id         String   @id @default(uuid())
  userId     String
  rewardId   String
  redeemedAt DateTime @default(now())
  reward     Reward   @relation(fields: [rewardId], references: [id])
  user       Customer @relation(fields: [userId], references: [id])
}

model DriverRating {
  id        String   @id @default(uuid())
  driverId  String
  orderId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])

  @@unique([driverId, orderId])
}

model BranchTerminal {
  id             Int             @id @default(autoincrement())
  branchId       String
  token          String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  Branch         Branch          @relation(fields: [branchId], references: [id])
  TerminalStatus TerminalStatus?
}

model Campaign {
  id           Int       @id @default(autoincrement())
  name         String
  description  String?
  createdAt    DateTime  @default(now())
  scheduledFor DateTime?
  status       String    @default("draft")
  channelEmail Boolean   @default(true)
  segmentId    Int?
  content      String
  Segment      Segment?  @relation(fields: [segmentId], references: [id])
}

model CloudPrinter {
  id         Int      @id @default(autoincrement())
  branchId   String
  printerId  String
  kitchen    String
  ipAddress  String
  type       String
  trustScore Int      @default(100)
  online     Boolean  @default(false)
  lastSync   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([branchId, printerId])
}

model Device {
  id           String   @id
  serialNumber String
  branchId     String
  activatedAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  status       String   @default("ACTIVE")
  Branch       Branch   @relation(fields: [branchId], references: [id])
}

model Offer {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  description  String?
  discountPct  Int?
  discountAmt  Int?
  freeDelivery Boolean   @default(false)
  minOrder     Int?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
}

model PrinterAnomaly {
  id        Int      @id @default(autoincrement())
  printerId String
  branchId  String
  type      String
  severity  Int
  createdAt DateTime @default(now())
}

model PrinterFleet {
  id         Int      @id @default(autoincrement())
  branchId   String
  printerId  String
  group      String
  policy     String?
  firmware   String?
  configHash String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([branchId, printerId])
}

model PrinterHealth {
  id          Int      @id @default(autoincrement())
  printerId   String
  branchId    String
  score       Int      @default(100)
  lastUpdated DateTime @default(now())
}

model PrinterQueue {
  id          Int       @id @default(autoincrement())
  kitchen     String
  payload     Json
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  status      String    @default("pending")
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  durationMs  Int?
  printedAt   DateTime?
}

model PrinterSecurity {
  id         Int      @id @default(autoincrement())
  printerId  String
  kitchen    String
  ipAddress  String
  approved   Boolean  @default(false)
  token      String
  trustScore Int      @default(100)
  tampered   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PrinterTrace {
  id         Int      @id @default(autoincrement())
  printerId  String
  kitchen    String
  branchId   String
  event      String
  durationMs Int?
  createdAt  DateTime @default(now())
}

model Segment {
  id         Int        @id @default(autoincrement())
  name       String
  createdAt  DateTime   @default(now())
  filterJson String
  Campaign   Campaign[]
}

model TerminalError {
  id         Int      @id @default(autoincrement())
  terminalId Int
  branchId   Int
  message    String
  severity   Int
  createdAt  DateTime @default(now())
}

model TerminalEvent {
  id        String   @id
  orderId   String
  event     String
  payload   String
  createdAt DateTime @default(now())
  order     Order    @relation("OrderTerminalEvents", fields: [orderId], references: [id])
}

model TerminalStatus {
  id               Int             @id @default(autoincrement())
  terminalId       Int
  branchId         Int
  online           Boolean         @default(false)
  lastSeen         DateTime        @default(now())
  assignedKitchen  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  branchTerminalId Int?            @unique
  BranchTerminal   BranchTerminal? @relation(fields: [branchTerminalId], references: [id])

  @@unique([terminalId, branchId])
}

model VirtualPrinter {
  id         Int       @id @default(autoincrement())
  kitchen    String
  instanceId String
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  releasedAt DateTime?
}

model Voucher {
  id        String    @id
  code      String    @unique
  amount    Decimal
  expiresAt DateTime?
  isUsed    Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Wallet {
  id                String              @id
  customerId        String              @unique
  balance           Decimal             @default(0.00)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  WalletTransaction WalletTransaction[]
}

model WalletTransaction {
  id        String          @id
  walletId  String
  type      TransactionType
  amount    Decimal
  reference String?
  createdAt DateTime        @default(now())
  Wallet    Wallet          @relation(fields: [walletId], references: [id])
}

model ingredients {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  allergen Boolean? @default(false)
  vegan    Boolean? @default(false)
}

model promotions {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String   @unique
  discount_type String
  amount        Decimal  @db.Decimal(10, 2)
  active        Boolean? @default(true)
}

model Cart {
  id         String     @id @default(uuid())
  customerId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]
}

model BranchSchedule {
  id        String @id @default(uuid())
  branchId  String
  day       Int
  openTime  String
  closeTime String
  branch    Branch @relation(fields: [branchId], references: [id])
}

model Category {
  id          String  @id @default(uuid())
  description String?
  name        String  @unique
  position    Int     @default(0)
  imageUrl    String?
  isAvailable Boolean @default(true)
}

model CartItem {
  id         String   @id @default(uuid())
  cartId     String?
  quantity   Int      @default(1)
  addOnIds   String[] @default([])
  basePrice  Float
  menuItemId Int
  orderId    String?
  totalPrice Float
  variantId  String?
  cart       Cart?    @relation(fields: [cartId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order?   @relation(fields: [orderId], references: [id])
}

model PriceHistory {
  id        String   @id @default(uuid())
  oldPrice  Float
  newPrice  Float
  reason    String
  createdAt DateTime @default(now())
  itemId    Int
  item      MenuItem @relation(fields: [itemId], references: [id])
}

model Relation {
  id        String   @id @default(uuid())
  variantId String?
  toppingId String?
  extraId   String?
  itemId    Int
  item      MenuItem @relation(fields: [itemId], references: [id])
}

model Address {
  id           String   @id @default(uuid())
  customerId   String
  label        String
  street       String
  city         String
  postalCode   String
  lat          Float?
  lng          Float?
  instructions String?
  isDefault    Boolean  @default(false)
  customer     Customer @relation(fields: [customerId], references: [id])
}

model Favorite {
  id         String   @id @default(uuid())
  customerId String
  createdAt  DateTime @default(now())
  itemId     Int
  customer   Customer @relation(fields: [customerId], references: [id])
  item       MenuItem @relation(fields: [itemId], references: [id])

  @@unique([customerId, itemId])
}

model LoyaltyPoints {
  id         String   @id @default(uuid())
  customerId String   @unique
  points     Int      @default(0)
  customer   Customer @relation(fields: [customerId], references: [id])
}

model NotificationPreference {
  id         String   @id @default(uuid())
  customerId String   @unique
  allowPush  Boolean  @default(true)
  allowSMS   Boolean  @default(false)
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Referral {
  id            String   @id @default(uuid())
  customerId    String   @unique
  code          String   @unique
  referredCount Int      @default(0)
  customer      Customer @relation(fields: [customerId], references: [id])
}

model MenuItem {
  name                     String
  description              String?
  baseImage                String?
  basePrice                Float?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  id                       Int                      @id @default(autoincrement())
  itemNumber               String?
  sortOrder                Int                      @default(0)
  imageUrl                 String?
  isAvailable              Boolean                  @default(true)
  kitchen                  String                   @default("B")
  addOnGroups              AddOnGroup[]
  branchItemAvailabilities BranchItemAvailability[]
  branchItemPricings       BranchItemPricing[]
  branchItems              BranchMenuItem[]
  CartItem                 CartItem[]
  Favorite                 Favorite[]
  extras                   MenuItemExtra[]
  notes                    MenuItemNote[]
  OrderItem                OrderItem[]
  PriceHistory             PriceHistory[]
  Relation                 Relation[]
  variantGroups            VariantGroup[]
}

model VariantGroup {
  id              String    @id @default(uuid())
  name            String
  itemId          Int
  required        Boolean   @default(false)
  minSelect       Int       @default(0)
  maxSelect       Int       @default(1)
  includedChoice  Boolean   @default(false)
  variants        Variant[]
  item            MenuItem  @relation(fields: [itemId], references: [id])
}

model Variant {
  id      String       @id @default(uuid())
  name    String
  price   Float
  groupId String
  group   VariantGroup @relation(fields: [groupId], references: [id])
}

model AddOnGroup {
  id        String   @id @default(uuid())
  name      String
  itemId    Int
  required  Boolean  @default(false)
  minSelect Int      @default(0)
  maxSelect Int      @default(5)
  addOns    AddOn[]
  item      MenuItem @relation(fields: [itemId], references: [id])
}

model AddOn {
  id      String     @id @default(uuid())
  name    String
  price   Float
  groupId String
  group   AddOnGroup @relation(fields: [groupId], references: [id])
}

model CourierLocation {
  id        String   @id @default(uuid())
  courierId String
  accuracy  Float?
  createdAt DateTime @default(now())
  latitude  Float
  longitude Float
  orderId   String?
  courier   Courier  @relation(fields: [courierId], references: [id])
  order     Order?   @relation("OrderCourierLocations", fields: [orderId], references: [id])

  @@index([courierId])
  @@index([orderId])
}

model OrderTrackingEvent {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  timestamp DateTime @default(now())
  order     Order    @relation("OrderTrackingEvents", fields: [orderId], references: [id])
}

model Review {
  id             String    @id @default(uuid())
  orderId        String    @unique
  customerId     String?
  branchId       String
  foodRating     Int
  deliveryRating Int?
  rating         Int?
  comment        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  branch         Branch    @relation(fields: [branchId], references: [id])
  customer       Customer? @relation(fields: [customerId], references: [id])
  order          Order     @relation("OrderReview", fields: [orderId], references: [id])

  @@index([branchId, createdAt])
}

model ItemRating {
  id          String    @id @default(uuid())
  orderItemId String    @unique
  rating      Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
}

model RiskScore {
  id        String   @id @default(uuid())
  orderId   String   @unique
  score     Int
  level     String
  createdAt DateTime @default(now())
  order     Order    @relation("OrderRiskScore", fields: [orderId], references: [id])
}

model OrderRiskEvent {
  id        String   @id @default(uuid())
  orderId   String
  event     String
  createdAt DateTime @default(now())
  order     Order    @relation("OrderOrderRiskEvents", fields: [orderId], references: [id])
}

model DeliveryZone {
  id                    String @id @default(uuid())
  branchId              String @unique
  maxDistanceKm         Float
  baseFee               Float
  perKmFee              Float
  freeDeliveryThreshold Float?
  minimumOrderAmount    Float?
  branch                Branch @relation(fields: [branchId], references: [id])
}

model KitchenDisplay {
  id        String   @id @default(uuid())
  name      String
  apiKey    String   @unique
  branchId  String
  createdAt DateTime @default(now())
  branch    Branch   @relation(fields: [branchId], references: [id])
}

model CustomerSession {
  id           String   @id @default(uuid())
  customerId   String
  refreshToken String   @unique
  userAgent    String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  customer     Customer @relation(fields: [customerId], references: [id])
}

model ManagerSession {
  id           String   @id @default(uuid())
  managerId    String
  refreshToken String   @unique
  userAgent    String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  manager      Manager  @relation(fields: [managerId], references: [id])
}

model AdminSession {
  id           String   @id @default(uuid())
  adminId      String
  refreshToken String   @unique
  userAgent    String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  admin        Admin    @relation(fields: [adminId], references: [id])
}

model DriverAccessToken {
  id        String   @id @default(uuid())
  orderId   String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivationCode {
  id        String    @id
  code      String    @unique
  branchId  String
  expiresAt DateTime
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  deviceId  String?
  Branch    Branch    @relation(fields: [branchId], references: [id])
}

model BranchConfig {
  id         String   @id
  branchId   String   @unique
  configJson Json
  version    Int      @default(1)
  updatedAt  DateTime @default(now())
  Branch     Branch   @relation(fields: [branchId], references: [id])
}

model BranchMenuItem {
  id          Int             @id @default(autoincrement())
  branchId    String
  menuItemId  Int
  price       Float?
  description String?
  imageUrl    String?
  isAvailable Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  categoryId  Int?
  branch      Branch          @relation(fields: [branchId], references: [id])
  category    BranchCategory? @relation(fields: [categoryId], references: [id])
  menuItem    MenuItem        @relation(fields: [menuItemId], references: [id])

  @@index([branchId, isAvailable])
}

model BranchCategory {
  id          Int                         @id @default(autoincrement())
  branchId    String
  name        String
  description String?
  sortOrder   Int                         @default(0)
  branch      Branch                      @relation(fields: [branchId], references: [id])
  items       BranchMenuItem[]
  extraPresets BranchExtraPresetCategory[]

  @@index([branchId])
}

model BranchExtraPreset {
  id         String                      @id @default(uuid())
  branchId   String
  name       String
  required   Boolean                     @default(false)
  minSelect  Int                         @default(0)
  maxSelect  Int                         @default(5)
  sortOrder  Int                         @default(0)
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt
  branch     Branch                      @relation(fields: [branchId], references: [id])
  options    BranchExtraPresetOption[]
  categories BranchExtraPresetCategory[]
}

model BranchExtraPresetOption {
  id        String            @id @default(uuid())
  presetId  String
  name      String
  price     Float             @default(0)
  sortOrder Int               @default(0)
  preset    BranchExtraPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
}

model BranchExtraPresetCategory {
  presetId   String
  categoryId Int
  preset     BranchExtraPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  category   BranchCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([presetId, categoryId])
}

model MenuItemExtra {
  id         Int      @id @default(autoincrement())
  menuItemId Int
  name       String
  price      Float?
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model MenuItemNote {
  id         Int      @id @default(autoincrement())
  menuItemId Int
  text       String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model GlobalSettings {
  id                   String  @id @default(uuid())
  enableSms            Boolean @default(false)
  enablePush           Boolean @default(false)
  enableEmail          Boolean @default(false)
  smsProvider          String  @default("none")
  pushProvider         String  @default("none")
  emailProvider        String  @default("none")
  notifyOrderPlaced    Boolean @default(true)
  notifyOrderAccepted  Boolean @default(true)
  notifyOutForDelivery Boolean @default(true)
  notifyDelivered      Boolean @default(true)
}

model PlatformConfig {
  id         String   @id @default("default")
  configJson Json
  updatedAt  DateTime @updatedAt
}

model BranchItemAvailability {
  id          String   @id @default(uuid())
  branchId    String
  menuItemId  Int
  isAvailable Boolean  @default(true)
  branch      Branch   @relation(fields: [branchId], references: [id])
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([branchId, menuItemId])
}

model BranchCustomer {
  id                  String    @id @default(uuid())
  branchId            String
  phone               String
  email               String?
  name                String?
  birthday            DateTime? @db.Date
  preferredChannel    String?
  marketingEmail      Boolean   @default(false)
  marketingSMS        Boolean   @default(false)
  marketingWhatsApp   Boolean   @default(false)
  consentAt           DateTime?
  orderCount          Int       @default(0)
  firstOrderAt        DateTime?
  lastOrderAt         DateTime?
  winBackOfferSentAt  DateTime?
  birthdayOfferSentAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([branchId, phone])
}

model PromoCode {
  id        String    @id @default(uuid())
  code      String    @unique
  type      String
  amount    Float
  minOrder  Float     @default(0)
  maxUses   Int?
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model BranchGiftCard {
  id              String    @id @default(uuid())
  branchId        String
  code            String    @unique
  initialAmount   Decimal   @db.Decimal(10, 2)
  balance         Decimal   @db.Decimal(10, 2)
  purchaserName   String?
  purchaserEmail  String?
  purchaserPhone  String?
  recipientName   String?
  message         String?
  paymentMethod   String?
  paymentStatus   String    @default("pending")
  paypalOrderId           String?
  paypalCaptureId         String?
  stripePaymentIntentId   String?
  isActive                Boolean   @default(true)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([branchId])
  @@index([branchId, paymentStatus])
}

model BranchItemPricing {
  id         String   @id @default(uuid())
  branchId   String
  menuItemId Int
  price      Float?
  branch     Branch   @relation(fields: [branchId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([branchId, menuItemId])
}

model BranchHours {
  id        String @id @default(uuid())
  branchId  String
  dayOfWeek Int
  openTime  String
  closeTime String
  branch    Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, dayOfWeek])
}

model OrderIssue {
  id           String   @id @default(uuid())
  orderId      String
  userId       String
  type         String
  description  String?
  status       String   @default("open")
  resolution   String?
  refundAmount Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id])
  user         Customer @relation(fields: [userId], references: [id])
}

model driver_locations {
  id         Int       @id @default(autoincrement())
  driver_id  Int
  lat        Float
  lng        Float
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model restaurant_settings {
  id             Int       @id @default(autoincrement())
  opening_hours  Json
  delivery_zones Json
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
}

enum TransactionType {
  CREDIT
  DEBIT
  REFUND
  VOUCHER
  PROMO
  TOPUP
}
