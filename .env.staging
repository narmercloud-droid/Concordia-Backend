# Staging Environment Configuration
NODE_ENV=staging
DATABASE_URL=postgresql://concordia:password@postgres:5432/concordia
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=staging-access-secret-key-change-in-production
JWT_REFRESH_SECRET=staging-refresh-secret-key-change-in-production
CORS_ORIGIN=https://staging.concordia.com
SOCKET_ORIGIN=https://staging.concordia.com
LOG_LEVEL=info