# Server
NODE_ENV=production
PORT=4000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=replace_with_openssl_rand_hex_32_or_longer_secret
JWT_EXPIRES_IN=7d

# Frontend (CORS + courier QR links)
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app

# Phase 1 cash-only launch — skips PayPal/Redis requirement in production
# Set to false when card payments are live
CASH_ONLY_LAUNCH=true

# Redis (optional for cash-only; enables distributed rate limiting)
# REDIS_URL=redis://localhost:6379

# PayPal — card + PayPal checkout (sandbox or live)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox
# PAYPAL_WEBHOOK_ID=

# Seed scripts — required when running npm run seed:admins / seed:concordia (min 12 chars)
SEED_ADMIN_PASSWORD=

# Web push — browser order notifications (optional)
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Optional
LOG_LEVEL=info
SENTRY_DSN=
