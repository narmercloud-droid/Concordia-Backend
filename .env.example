# Server
NODE_ENV=production
PORT=4000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=your_jwt_secret_min_10_chars
JWT_EXPIRES_IN=7d

# Frontend (CORS + courier QR links)
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app

# Phase 1 cash-only launch — skips PayPal/Redis requirement in production
CASH_ONLY_LAUNCH=true

# Redis (optional for cash-only; enables distributed rate limiting)
# REDIS_URL=redis://localhost:6379

# PayPal (Phase 2+)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox

# Seed script — default admin password
# SEED_ADMIN_PASSWORD=Kempen2026!

# Optional
LOG_LEVEL=info
SENTRY_DSN=
